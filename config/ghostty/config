background-blur-radius = 21
background-opacity = 0.8

selection-invert-fg-bg = true

bold-color = bright

clipboard-read = allow

cursor-style-blink = false

font-family = "Iosevka Term SS15"
font-size = 16

macos-icon = glass
macos-option-as-alt = true

mouse-hide-while-typing = true
mouse-shift-capture = true

quit-after-last-window-closed = true

shell-integration-features = no-cursor,no-sudo,title

theme = light:base16-default-light,dark:base16-default-dark

unfocused-split-fill = 000000
unfocused-split-opacity = 0.5

keybind = shift+enter=text:\n
keybind = super+ctrl+equal=equalize_splits
keybind = super+shift+p=toggle_command_palette
