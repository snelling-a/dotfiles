#!/bin/bash
# prepend conventional commit type or ticket tag if branch has one in it

COMMIT_MSG_FILE=$1
COMMIT_SOURCE=$2
# SHA1=$3

# Check for GNU sed (required for 0,/pattern/ syntax)
if command -v gsed &>/dev/null; then
  SED="gsed"
elif sed --version 2>&1 | grep -q "GNU sed"; then
  SED="sed"
else
  echo "Error: GNU sed is required but not found. Install with: brew install gnu-sed"
  exit 1
fi

# exit if commit is a fixup
grep -q 'fixup' "$COMMIT_MSG_FILE" && exit 0

# get current branch
branch_name=$(git rev-parse --abbrev-ref HEAD)

conventional_commit_types=(
  "build"
  "chore"
  "ci"
  "docs"
  "feat"
  "fix"
  "perf"
  "refactor"
  "revert"
  "style"
  "test"
)

# optional (scope): — allow hyphens so fix(BLUE-123): matches ([[:alnum:]_]+ alone did not)
cc_scope_e='(\([^)]*\))?'

# conventional slug: leading word before optional "/" (case-insensitive → lowercase)
branch_slug=$(
  echo "$branch_name" | $SED -nr 's,^([[:alpha:]]+)/?.+,\1,p' | tr '[:upper:]' '[:lower:]'
)

conventional_commit_type=
if [[ " ${conventional_commit_types[*]} " == *" $branch_slug "* ]]; then
  conventional_commit_type=$branch_slug
fi

if [[ -n "$conventional_commit_type" ]]; then
  # conventional prefix wins over ticket id (e.g. feat/BLUE-123-x → feat: only)
  for type in "${conventional_commit_types[@]}"; do
    grep -Eqi "^${type}${cc_scope_e}:" "$COMMIT_MSG_FILE" && exit 0
  done

  printf "\n Prepending conventional commit type to commit message...\n\n"

  # Linear / templates often pre-fill "BLUE-8707: "; strip so we do not stack prefixes
  strip_leading_ticket='1s/^[[:alnum:]]\+-[[:digit:]]\+:[[:space:]]*//'

  if [[ "$COMMIT_SOURCE" == "template" ]]; then
    sed_expr="0,/^$/{s/^$/$conventional_commit_type: /}"
  else
    sed_expr="1s/^/$conventional_commit_type: /"
  fi

  $SED -i.bak -e "$strip_leading_ticket" -e "$sed_expr" "$COMMIT_MSG_FILE"
  rm -f "$COMMIT_MSG_FILE.bak"
else
  # issue id in branch: leading KEY-NUMBER slug (e.g. abc-8707-description)
  ticket_id=$(echo "$branch_name" | $SED -nr 's,^([A-Za-z0-9]+-[0-9]+)-.+,\1,p' | tr '[:lower:]' '[:upper:]')

  if [[ -n "$ticket_id" ]]; then
    # line 1 already type(scope): — don't prepend ticket (e.g. refactor(...) before BLUE-* hook ran)
    first_line=$(head -n 1 "$COMMIT_MSG_FILE")
    for type in "${conventional_commit_types[@]}"; do
      printf '%s\n' "$first_line" | grep -Eqi "^${type}${cc_scope_e}:" && exit 0
    done

    grep -qi "^$ticket_id:" "$COMMIT_MSG_FILE" && exit 0

    printf "\n Prepending issue id to commit message...\n\n"

    if [[ "$COMMIT_SOURCE" == "template" ]]; then
      sed_expr="0,/^$/{s/^$/$ticket_id: /}"
    else
      sed_expr="1s/^/$ticket_id: /"
    fi

    $SED -i.bak -e "$sed_expr" "$COMMIT_MSG_FILE"
    rm -f "$COMMIT_MSG_FILE.bak"
  fi
fi
